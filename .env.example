HEALTH_CONNECT_LINK_ATTEMPT_LIMIT=5
HEALTH_CONNECT_LINK_ATTEMPT_WINDOW_SECONDS=900
HEALTH_CONNECT_MAX_BATCH_SIZE=25
OUTBOX_POLL_SECONDS=5
BOT_OWNER_TELEGRAM_ID=
AI_ENABLED=false
AI_DEFAULT_PROVIDER=OPENAI
AI_OPENAI_API_KEY=
